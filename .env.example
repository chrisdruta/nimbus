# SoundCloud app credentials (register at https://developers.soundcloud.com — requires Artist Pro).
# Redirect URI to register for local dev: http://localhost:3000/api/auth/callback
SOUNDCLOUD_CLIENT_ID=
SOUNDCLOUD_CLIENT_SECRET=

# 32 bytes, base64 — generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=
# Optional during key rotation. Keep the old key here until every token has
# been rewritten with TOKEN_ENCRYPTION_KEY, then remove it.
TOKEN_ENCRYPTION_KEY_PREVIOUS=

# Any long random string — generate with: openssl rand -base64 32
SESSION_SECRET=

# Neon Postgres connection string (postgres://...)
DATABASE_URL=

# Origin the app runs on; drives the OAuth redirect_uri.
APP_URL=http://localhost:3000

# Fine-grained GitHub PAT scoped to this repo only (contents + pull requests
# read/write). Used by gh/git for Dependabot PR maintenance; not needed to run
# the app.
GH_TOKEN=

# Numeric SoundCloud user id allowed to sign in during the spike.
# Leave unset for the first login attempt: the callback rejects you with 403
# and logs your numeric id, which you then paste here.
OWNER_SC_USER_ID=
